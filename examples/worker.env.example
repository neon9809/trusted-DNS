# Trusted-DNS Worker Environment Variables
#
# These variables should be configured in your wrangler.toml [vars] section
# or set as Cloudflare Workers secrets.
#
# Required: Shared secret (must match Docker node ROOT_SEED)
# Generate with: openssl rand -hex 32
ROOT_SEED = "replace-with-your-64-char-hex-seed"

# Required: DoH upstream resolvers (JSON array)
DOH_UPSTREAMS = '["https://dns.google/dns-query","https://cloudflare-dns.com/dns-query","https://1.1.1.1/dns-query"]'

# Optional: Multi-client registry (JSON array string)
# Replace the sample root_seed values with your own 64-character hex seeds.
# Remove this variable entirely if you want single-client mode with ROOT_SEED.
CLIENT_REGISTRY = '[{"root_seed":"0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef","enabled":true},{"root_seed":"abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789","enabled":true}]'

# Optional: DoH request timeout in milliseconds (default: 5000)
DOH_TIMEOUT_MS = "5000"

# Optional: Enable debug mode (default: false)
# WARNING: Debug mode may log sensitive information. Do NOT enable in production.
DEBUG_MODE = "false"

# Optional: Custom protocol endpoint path (default: /dns-query)
# Must match PROTOCOL_PATH on Docker side if customized.
# PROTOCOL_PATH = "/dns-query"
